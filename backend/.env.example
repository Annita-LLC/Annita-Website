# Railway Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require
# Alternative Railway format (recommended)
RAILWAY_ENVIRONMENT=production

# Server Configuration
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://www.an-nita.com
API_BASE_URL=https://your-backend-url.railway.app

# Security Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-here-min-256-bits
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@an-nita.com
RESEND_TO_EMAIL=admin@an-nita.com
APP_NAME=Annita

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# CORS Configuration
CORS_ORIGIN=https://www.an-nita.com
CORS_CREDENTIALS=true

# Form Submission Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# Staff Portal Configuration
STAFF_JWT_SECRET=your-staff-portal-jwt-secret-different-from-main
STAFF_SESSION_EXPIRES_IN=24h

# Monitoring & Health Checks
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
